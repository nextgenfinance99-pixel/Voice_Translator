# Deepgram API Key - Get yours at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Cloud Project ID - Get yours at https://console.cloud.google.com
GOOGLE_PROJECT_ID=your_google_project_id_here

# Optional: Path to Google Cloud service account key JSON file
# If not set, uses Application Default Credentials (ADC)
# GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account-key.json

# Server port
PORT=3000
