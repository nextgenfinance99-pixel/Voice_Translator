# Deepgram API Key - Get yours at https://console.deepgram.com
DEEPGRAM_API_KEY=

# Google Cloud Translation API Key (v2)
# Get yours at: https://console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Make sure the "Cloud Translation API" is enabled on your project
GOOGLE_TRANSLATE_API_KEY=

# Server port
PORT=3000
